digraph tt_um_solve2x2_q16 {
    rankdir=TB
    fontname="Helvetica"
    node [fontname="Helvetica", fontsize=12]
    edge [fontname="Helvetica", fontsize=10]

    // -------------------------------------------------------------------------
    // Input streaming
    // -------------------------------------------------------------------------
    subgraph cluster_inputs {
        label="Input Streaming (12 bytes, LSB first)"
        style=dashed
        color=gray
        fontsize=11

        a [label="a\n[15:0]", shape=box, style=filled, fillcolor="#D6EAF8"]
        b [label="b\n[15:0]", shape=box, style=filled, fillcolor="#D6EAF8"]
        c [label="c\n[15:0]", shape=box, style=filled, fillcolor="#D6EAF8"]
        d [label="d\n[15:0]", shape=box, style=filled, fillcolor="#D6EAF8"]
        e [label="e\n[15:0]", shape=box, style=filled, fillcolor="#D6EAF8"]
        f [label="f\n[15:0]", shape=box, style=filled, fillcolor="#D6EAF8"]
    }

    // -------------------------------------------------------------------------
    // Multipliers
    // -------------------------------------------------------------------------
    subgraph cluster_mul {
        label="Multipliers (16×16 → 32-bit)"
        style=dashed
        color=gray
        fontsize=11

        mul_ad [label="a × d", shape=ellipse, style=filled, fillcolor="#D5F5E3"]
        mul_bc [label="b × c", shape=ellipse, style=filled, fillcolor="#D5F5E3"]
        mul_de [label="d × e", shape=ellipse, style=filled, fillcolor="#D5F5E3"]
        mul_bf [label="b × f", shape=ellipse, style=filled, fillcolor="#D5F5E3"]
        mul_ce [label="c × e", shape=ellipse, style=filled, fillcolor="#D5F5E3"]
        mul_af [label="a × f", shape=ellipse, style=filled, fillcolor="#D5F5E3"]
    }

    a -> mul_ad
    d -> mul_ad
    b -> mul_bc
    c -> mul_bc
    d -> mul_de
    e -> mul_de
    b -> mul_bf
    f -> mul_bf
    c -> mul_ce
    e -> mul_ce
    a -> mul_af
    f -> mul_af

    // -------------------------------------------------------------------------
    // Subtractors → det, num0, num1
    // -------------------------------------------------------------------------
    det  [label="det = a·d − b·c\n[32:0] signed", shape=box, style=filled, fillcolor="#FDEBD0"]
    num0 [label="num0 = d·e − b·f\n[32:0] signed", shape=box, style=filled, fillcolor="#FDEBD0"]
    num1 [label="num1 = −c·e + a·f\n[32:0] signed", shape=box, style=filled, fillcolor="#FDEBD0"]

    mul_ad -> det [label="−"]
    mul_bc -> det
    mul_de -> num0 [label="−"]
    mul_bf -> num0
    mul_ce -> num1 [label="negate +"]
    mul_af -> num1

    // -------------------------------------------------------------------------
    // Singular check
    // -------------------------------------------------------------------------
    sing_check [label="det == 0?", shape=diamond, style=filled, fillcolor="#FADBD8"]
    det -> sing_check

    singular_out [label="singular=1\nx0=0, x1=0\nvalid=1", shape=box, style=filled, fillcolor="#FADBD8"]
    sing_check -> singular_out [label="yes"]

    // -------------------------------------------------------------------------
    // Shift left 16
    // -------------------------------------------------------------------------
    shift0 [label="num0 << 16\n[48:0] signed", shape=box, style=filled, fillcolor="#F9E79F"]
    shift1 [label="num1 << 16\n[48:0] signed", shape=box, style=filled, fillcolor="#F9E79F"]

    num0 -> shift0
    num1 -> shift1
    sing_check -> shift0 [label="no"]

    // -------------------------------------------------------------------------
    // Restoring divider
    // -------------------------------------------------------------------------
    divider [label="Restoring Divider\n48-bit ÷ 33-bit\n48 cycles/divide", shape=box,
             style=filled, fillcolor="#E8DAEF", width=2.5]

    shift0 -> divider [label="numerator (x0)"]
    shift1 -> divider [label="numerator (x1)"]
    det    -> divider [label="denominator"]

    // -------------------------------------------------------------------------
    // Saturator
    // -------------------------------------------------------------------------
    sat [label="Saturator\nclamp to signed 32-bit\n0x7FFFFFFF / 0x80000000", shape=box,
         style=filled, fillcolor="#E8DAEF"]

    divider -> sat [label="48-bit quotient"]

    // -------------------------------------------------------------------------
    // Output registers
    // -------------------------------------------------------------------------
    x0 [label="x0\n[31:0] Q16.16", shape=box, style=filled, fillcolor="#D6EAF8", width=1.5]
    x1 [label="x1\n[31:0] Q16.16", shape=box, style=filled, fillcolor="#D6EAF8", width=1.5]

    sat -> x0 [label="first divide"]
    sat -> x1 [label="second divide"]

    // -------------------------------------------------------------------------
    // Output mux
    // -------------------------------------------------------------------------
    mux [label="Output Mux\nsel → x0 or x1\nbyte_sel[1:0] → byte", shape=box,
         style=filled, fillcolor="#D5F5E3"]

    x0 -> mux
    x1 -> mux

    uo_out [label="uo_out[7:0]", shape=box, style=filled, fillcolor="#AED6F1", width=1.5]
    mux -> uo_out

    // -------------------------------------------------------------------------
    // Status flags
    // -------------------------------------------------------------------------
    flags [label="uio_out[2:0]\nvalid | singular | overflow", shape=box,
           style=filled, fillcolor="#AED6F1"]

    sat        -> flags [label="overflow"]
    sing_check -> flags [label="singular"]
    x1         -> flags [label="valid"]

    // -------------------------------------------------------------------------
    // FSM (separate rank)
    // -------------------------------------------------------------------------
    subgraph cluster_fsm {
        label="FSM"
        style=filled
        fillcolor="#FDFEFE"
        color="#AAB7B8"
        fontsize=11

        S_IDLE    [label="S_IDLE",    shape=circle, style=filled, fillcolor="#AED6F1"]
        S_LOAD    [label="S_LOAD\n(11 cycles)", shape=circle, style=filled, fillcolor="#AED6F1"]
        S_COMPUTE [label="S_COMPUTE", shape=circle, style=filled, fillcolor="#AED6F1"]
        S_DIV_X0  [label="S_DIV_X0",  shape=circle, style=filled, fillcolor="#A9DFBF"]
        S_DIV_X1  [label="S_DIV_X1\n(48 cycles)", shape=circle, style=filled, fillcolor="#A9DFBF"]
        S_DONE    [label="S_DONE",    shape=circle, style=filled, fillcolor="#F9E79F"]

        S_IDLE    -> S_LOAD    [label="start"]
        S_LOAD    -> S_COMPUTE [label="cnt==11"]
        S_COMPUTE -> S_DIV_X0
        S_DIV_X0  -> S_DONE    [label="det==0\n(singular)"]
        S_DIV_X0  -> S_DIV_X1  [label="det≠0\ndiv_start"]
        S_DIV_X1  -> S_DONE    [label="div_done\n(x0 captured,\nx1 div started)"]
        S_DONE    -> S_LOAD    [label="start\n(back-to-back)"]
        S_DONE    -> S_IDLE    [label="start\n(from idle)"]
    }
}
